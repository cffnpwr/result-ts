{
  "lsp": {
    "nixd": {
      "settings": {
        "formatting": {
          "command": ["nixfmt"],
        },
      },
    },
  },
  "languages": {
    "Nix": {
      "language_servers": ["nixd", "!nil", "..."],
      "formatter": "language_server",
      "semantic_tokens": "combined",
    },
    "TypeScript": {
      "prettier": { "allowed": false },
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "format_on_save": "on",
    },
  },
}
