{
  "name": "@cffnpwr/result-ts",
  "version": "1.1.1",
  "private": false,
  "description": "Rust like Result type for TypeScript",
  "homepage": "https://github.com/cffnpwr/result-ts",
  "bugs": "https://github.com/cffnpwr/result-ts/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/cffnpwr/result-ts.git"
  },
  "license": "MIT",
  "author": "cffnpwr",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "build-package": "bun scripts/build-package.ts",
    "test": "bun test src",
    "test:coverage": "bun test src --coverage",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "runtime-test": "bun scripts/runtime-test.ts",
    "publish:jsr": "jsr publish"
  },
  "devDependencies": {
    "@cffnpwr/eslint-config": "1.2.0",
    "@types/bun": "1.3.14",
    "@typescript-eslint/parser": "8.63.0",
    "eslint": "10.6.0",
    "eslint-config-flat-gitignore": "2.3.0",
    "globals": "17.7.0",
    "jsr": "0.14.3",
    "ts-morph": "28.0.0",
    "tsdown": "0.22.4",
    "typescript": "6.0.3",
    "zod": "4.4.3"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs",
        "types": "./dist/index.d.ts"
      },
      "./package.json": "./package.json"
    }
  }
}
